<?xml version="1.0" encoding="utf-8"?>
<!--
  PclRelease.props – Property sheet for PCL 1.14.1 (x64 Release)
  ---------------------------------------------------------------
  In CI this file is auto-generated by the GitHub Actions workflow.
  For local development, edit the paths below to match your PCL 1.14.1
  installation.  The PCL AllInOne installer for MSVC 2022 is available at:
    https://github.com/PointCloudLibrary/pcl/releases/tag/pcl-1.14.1

  Default install prefix: C:\PCL
  Expected layout inside that prefix:
    include\pcl-1.14\          – PCL public headers
    lib\                       – PCL .lib files  (pcl_*_release.lib)
    bin\                       – PCL .dll files  (pcl_*_release.dll)
    3rdParty\Eigen\eigen3\     – Eigen header-only library
    3rdParty\VTK\include\vtk-9.x\  – VTK headers
    3rdParty\VTK\lib\          – VTK .lib files
    3rdParty\VTK\bin\          – VTK .dll files
    3rdParty\Boost\include\boost-1_xx\  – Boost headers
    3rdParty\Boost\lib\        – Boost .lib files
    3rdParty\FLANN\include\    – FLANN headers
    3rdParty\FLANN\lib\        – FLANN .lib files
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros">
    <!-- Root install directory – override by setting PCL_ROOT env variable -->
    <PCLDir Condition="'$(PCLDir)'=='' AND '$(PCL_ROOT)'!=''">$(PCL_ROOT)</PCLDir>
    <PCLDir Condition="'$(PCLDir)'==''">C:\PCL</PCLDir>
  </PropertyGroup>
  <PropertyGroup />
  <ItemDefinitionGroup>
    <ClCompile>
      <!--
        Adjust the versioned sub-directory names (pcl-1.14, vtk-9.x, boost-1_xx)
        to match your actual installation.
      -->
      <AdditionalIncludeDirectories>
        $(PCLDir)\include\pcl-1.14;
        $(PCLDir)\3rdParty\VTK\include\vtk-9.3;
        $(PCLDir)\3rdParty\Boost\include\boost-1_84;
        $(PCLDir)\3rdParty\Eigen\eigen3;
        $(PCLDir)\3rdParty\FLANN\include;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
      <PreprocessorDefinitions>FLANN_STATIC;_USE_MATH_DEFINES;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <AdditionalLibraryDirectories>
        $(PCLDir)\lib;
        $(PCLDir)\3rdParty\VTK\lib;
        $(PCLDir)\3rdParty\Boost\lib;
        $(PCLDir)\3rdParty\FLANN\lib;
        %(AdditionalLibraryDirectories)
      </AdditionalLibraryDirectories>
      <!--
        PCL release libs – all pcl_*_release.lib files in $(PCLDir)\lib.
        VTK libs         – version suffix (e.g. -9.3) must match your VTK install.
        These defaults target PCL 1.14.1 + VTK 9.3 from the AllInOne installer.
        The CI workflow regenerates this section automatically.
      -->
      <AdditionalDependencies>
        pcl_common_release.lib;
        pcl_filters_release.lib;
        pcl_io_release.lib;
        pcl_io_ply_release.lib;
        pcl_features_release.lib;
        pcl_kdtree_release.lib;
        pcl_octree_release.lib;
        pcl_sample_consensus_release.lib;
        pcl_search_release.lib;
        pcl_segmentation_release.lib;
        pcl_surface_release.lib;
        vtkCommonCore-9.3.lib;
        vtkCommonDataModel-9.3.lib;
        vtkCommonExecutionModel-9.3.lib;
        vtkCommonMath-9.3.lib;
        vtkCommonMisc-9.3.lib;
        vtkCommonSystem-9.3.lib;
        vtkCommonTransforms-9.3.lib;
        vtkIOCore-9.3.lib;
        vtkIOGeometry-9.3.lib;
        vtksys-9.3.lib;
        %(AdditionalDependencies)
      </AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup />
</Project>
